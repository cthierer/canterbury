meta {
  name: MintToken - Unmapped
  type: http
  seq: 3
  tags: [
    pomerium-auth-failed-audit
    pomerium-mcp-authz
  ]
}

post {
  url: {{DexBaseURI}}/token
  body: formUrlEncoded
  auth: none
}

headers {
  content-type: application/x-www-form-urlencoded
}

body:form-urlencoded {
  grant_type: password
  scope: openid profile email
  client_id: {{DexClientID}}
  client_secret: {{DexClientSecret}}
  username: unmapped@canterbury.local
  password: {{DexTestPassword}}
}

script:post-response {
  const body = typeof res.getBody === 'function' ? res.getBody() : res.body;
  bru.setVar('UnmappedToken', body.id_token);
}

tests {
  const body = typeof res.getBody === 'function' ? res.getBody() : res.body;

  test('mints unmapped ID token', function () {
    expect(body.id_token).to.be.a('string');
    expect(body.id_token.length).to.be.greaterThan(20);
  });
}
