meta {
  name: MCP ReadNote - Agent Authorized
  type: http
  seq: 40
  tags: [
    pomerium-mcp-read-audit
  ]
}

post {
  url: {{PomeriumBaseURI}}/mcp
  body: json
  auth: none
}

headers {
  accept: application/json, text/event-stream
  content-type: application/json
  mcp-protocol-version: 2025-06-18
  authorization: Bearer {{AgentToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "tools/call",
    "params": {
      "name": "read_note",
      "arguments": {
        "ref": {
          "path": "Projects/Canterbury.md"
        }
      }
    }
  }
}

tests {
  const status = typeof res.getStatus === 'function' ? res.getStatus() : res.status;
  const body = typeof res.getBody === 'function' ? res.getBody() : res.body;

  test('read_note returns expected project note', function () {
    expect(status).to.equal(200);
    expect(body.error).to.equal(undefined);
    expect(body.result.isError).to.not.equal(true);
    expect(body.result.structuredContent.note.ref.path).to.equal('Projects/Canterbury.md');
  });
}
