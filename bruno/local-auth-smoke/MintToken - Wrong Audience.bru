meta {
  name: MintToken - Wrong Audience
  type: http
  seq: 6
  tags: [
    smoke-auth
  ]
}

post {
  url: {{DevAuthBaseURI}}/canterbury.dev.v1.DevAuthService/MintToken
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "claims": {
      "subject": "user_123",
      "audiences": ["not-canterbury.vault.local"]
    },
    "options": {
      "ttlSeconds": 900
    }
  }
}

script:post-response {
  const body = typeof res.getBody === 'function' ? res.getBody() : res.body;
  bru.setVar('WrongAudienceToken', body.token.jwt);
}

tests {
  const body = typeof res.getBody === 'function' ? res.getBody() : res.body;

  test('mints wrong-audience token', function () {
    expect(body.token.jwt).to.be.a('string');
    expect(body.token.jwt.length).to.be.greaterThan(20);
  });
}
