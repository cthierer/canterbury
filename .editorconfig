# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2
tab_width = 2

# TypeScript/JavaScript files
[*.{ts,tsx,js,jsx}]
indent_style = tab
indent_size = 2
tab_width = 2
max_line_length = 100

# JSON files
[*.json]
indent_style = tab
indent_size = 2
tab_width = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Package files
[package.json]
indent_style = tab
indent_size = 2

# Configuration files
[*.{toml,ini}]
indent_style = space
indent_size = 2

# CSS/SCSS files
[*.{css,scss,sass}]
indent_style = tab
indent_size = 2
tab_width = 2

# HTML files
[*.{html,htm}]
indent_style = tab
indent_size = 2
tab_width = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# Makefiles
[Makefile]
indent_style = tab
